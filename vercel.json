{
  "buildCommand": "echo 'Static files only'",
  "outputDirectory": "public",
  "public": true,
  "rewrites": [
    {
      "source": "/",
      "destination": "/landing-page-masterclass.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600"
        }
      ]
    }
  ]
}
